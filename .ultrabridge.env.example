# UltraBridge Bootstrap Configuration
# This file contains only bootstrap environment variables.
# All other configuration (sources, OCR, logging, etc.) is managed via the Settings UI.

# ── Bootstrap Variables (Required) ─────────────────────────────────────────────
# These are the ONLY environment variables used at startup.
# After first boot, configure everything else via the Settings UI.

# SQLite database path for persistent storage (notes, tasks, settings)
UB_DB_PATH=/data/ultrabridge.db

# SQLite database path for task storage (CalDAV sync)
UB_TASK_DB_PATH=/data/ultrabridge-tasks.db

# Server port and address
UB_LISTEN_ADDR=:8443

# For unattended installer mode (optional)
# UB_PORT=8443
# UB_USERNAME=admin
# UB_PASSWORD=yourpassword
