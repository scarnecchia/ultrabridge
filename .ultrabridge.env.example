# UltraBridge Configuration
# Copy to .ultrabridge.env and customize

# Auth (REQUIRED)
UB_USERNAME=admin
UB_PASSWORD_HASH=$2a$10$... # Generate with: htpasswd -nbBC 10 "" "yourpassword" | cut -d: -f2

# CalDAV
UB_CALDAV_COLLECTION_NAME=Supernote Tasks
UB_DUE_TIME_MODE=preserve

# Server
UB_LISTEN_ADDR=:8443
UB_WEB_ENABLED=true

# Logging
UB_LOG_LEVEL=info
UB_LOG_FORMAT=json
# UB_LOG_FILE=/var/log/ultrabridge/ultrabridge.log
# UB_LOG_SYSLOG_ADDR=udp://graylog:1514

# Database (auto-read from .dbenv, rarely need to override)
# UB_DB_HOST=mariadb
# UB_DB_PORT=3306
# UB_SUPERNOTE_DBENV_PATH=/run/secrets/dbenv

# Socket.io (auto-discovered, rarely need to override)
# UB_SOCKETIO_URL=ws://supernote-service:8080/socket.io/

# ── Notes Pipeline ─────────────────────────────────────────────────────────────
# Set UB_NOTES_PATH to enable the Files tab and note ingestion.
# All pipeline vars are optional; omitting them leaves the pipeline disabled.

# Root directory where .note files are stored (mounted from Supernote NFS/volume)
# UB_NOTES_PATH=/mnt/supernote/note

# SQLite database for the notes pipeline (separate from Supernote's MariaDB)
# UB_DB_PATH=/data/ultrabridge.db

# Copy original .note to this directory before any OCR write (recommended)
# UB_BACKUP_PATH=/data/note-backups

# OCR via vision API
# UB_OCR_ENABLED=false
# UB_OCR_FORMAT=anthropic                         # anthropic (default) or openai
# UB_OCR_API_URL=https://openrouter.ai/api        # or https://api.anthropic.com, or http://localhost:8000 for vLLM
# UB_OCR_API_KEY=sk-...                           # leave blank for unauthenticated local endpoints
# UB_OCR_MODEL=anthropic/claude-opus-4-6          # or claude-opus-4-6 for direct Anthropic, or vLLM model name
# UB_OCR_CONCURRENCY=1                            # parallel OCR workers
# UB_OCR_MAX_FILE_MB=0                            # 0 = no size limit; set e.g. 50 to skip large files

# ── Task Store ──────────────────────────────────────────────────────────────
# Path to the SQLite database for task storage.
# UB_TASK_DB_PATH=/data/ultrabridge-tasks.db

# ── Supernote Task Sync ─────────────────────────────────────────────────────
# Enable sync between UltraBridge and Supernote device via SPC REST API.
# Requires Supernote Private Cloud to be running and accessible.
# UB_SN_SYNC_ENABLED=false

# Supernote account email (used for SPC authentication).
# UB_SN_ACCOUNT=user@example.com

# Sync interval in seconds (default: 300 = 5 minutes).
# UB_SN_SYNC_INTERVAL=300

# SPC REST API URL. Usually the internal Docker network address.
# UB_SN_API_URL=http://supernote-service:8080

# SPC password (plaintext, used for challenge-response auth).
# This is separate from UB_PASSWORD_HASH — SPC requires the plaintext
# password for SHA-256 challenge-response, while UltraBridge uses bcrypt.
# UB_SN_PASSWORD=
